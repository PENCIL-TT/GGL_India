{
  "rewrites": [
    {
      "source": "/india_kyc",
      "destination": "/api/india_kyc?path="
    },
    {
      "source": "/india_kyc/",
      "destination": "/api/india_kyc?path="
    },
    {
      "source": "/india_kyc/index.php",
      "destination": "/api/india_kyc?path=index.php"
    },
    {
      "source": "/india_kyc/:path*",
      "destination": "/api/india_kyc?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
